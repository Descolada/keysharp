[Unit]
Description=Keysharp privileged Linux input broker
Requires=keysharp-inputd.socket
After=keysharp-inputd.socket systemd-udevd.service keyd.service
# Soft ordering hint only (no Wants=/Requires=): if keyd is installed and
# starts around the same time as this unit, let it grab raw physical devices
# first so we correctly end up downstream of it (grabbing keyd's re-emitted
# virtual keyboard, per protocol.h's vendor-masquerade design) rather than
# racing it for the raw device. Harmless no-op if keyd.service does not exist
# on this system -- systemd silently ignores an After= on a unit that isn't
# present. Does not (and cannot) fully solve the race: this daemon is
# socket-activated, so it may start on first client connection at any later
# time regardless of boot ordering.

[Service]
Type=simple
ExecStart=@CMAKE_INSTALL_FULL_BINDIR@/keysharp-inputd --system-service
# Recover promptly if the daemon crashes while devices are grabbed (the kernel
# releases grabs on exit, so this fails open; restart re-establishes hooking).
Restart=on-failure
RestartSec=1
# This daemon sits between the keyboard and the whole system; being paged out or
# OOM-killed turns into system-wide input lag/loss. Deprioritize it for the OOM
# killer and allow it to lock its (small, bounded) resident set via mlockall.
OOMScoreAdjust=-900
LimitMEMLOCK=infinity
NoNewPrivileges=yes
ProtectClock=yes
ProtectControlGroups=yes
ProtectKernelLogs=yes
ProtectKernelModules=yes
ProtectKernelTunables=yes
ProtectSystem=strict
ReadWritePaths=/var/lib/keysharp-trust
StateDirectory=keysharp-trust
UMask=0077
DevicePolicy=closed
DeviceAllow=char-input r
DeviceAllow=/dev/uinput rw
