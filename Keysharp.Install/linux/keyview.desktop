[Desktop Entry]
Type=Application
Name=Keyview
Exec=/usr/local/bin/keyview %f
Icon=keysharp
Terminal=false
Categories=Utility;Development;
MimeType=application/x-keysharp;application/x-autohotkey;
InitialPreference=10
Actions=Edit;

[Desktop Action Edit]
Name=Edit Keysharp Script
Exec=/usr/local/bin/keyview --edit %f
